{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["clear-text", "progress", "html"],
  "testRunner": "mocha",
  "mochaOptions": {
    "spec": ["test/**/*.ts"]
  },
  "coverageAnalysis": "perTest",
  "mutate": ["src/**/*.ts"],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 0
  },
  "disableTypeChecks": false,
  "ignorePatterns": [
    "coverage",
    "reports",
    ".stryker-tmp",
    "dist",
    "node_modules/.cache"
  ],
  "timeoutMS": 30000
}
