{
  "name": "signalk-derived-data",
  "version": "1.45.0",
  "description": "Plugin that derives signalk data from other signalk data",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "//": "Floor at 20.10 to support Venus CerboGX firmware (currently Node 20.18.2). Bump back to >=22 once Cerbo ships a newer Node.",
    "node": ">=20.10"
  },
  "files": [
    "dist",
    "logo.svg",
    "docs/screenshots",
    "README.md",
    "LICENSE"
  ],
  "signalk": {
    "displayName": "SK Derived Data",
    "appIcon": "./logo.svg",
    "screenshots": [
      "./docs/screenshots/1_placeholder.png"
    ]
  },
  "scripts": {
    "precommit": "lint-staged",
    "prettier:check": "prettier --check .",
    "prettier": "prettier --write .",
    "format": "npm run prettier",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "mutation": "stryker run",
    "prepublishOnly": "npm run build"
  },
  "c8": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "test/**",
      "coverage/**",
      "dist/**",
      "src/types.ts",
      "src/types/**",
      "src/calcs/__*.ts"
    ],
    "all": true,
    "reporter": [
      "text",
      "lcov"
    ]
  },
  "keywords": [
    "signalk-node-server-plugin"
  ],
  "author": {
    "name": "Scott Bender",
    "email": "scott@scottbender.net"
  },
  "contributors": [
    {
      "name": "Joachim Bakke"
    }
  ],
  "license": "Apache-2.0",
  "lint-staged": {
    "*.ts": "prettier --write"
  },
  "dependencies": {
    "cubic-spline": "^3.0.3",
    "geolib": "^3.3.1",
    "geolocation-utils": "^1.2.3",
    "geomagnetism": "^0.2.0",
    "suncalc": "^1.8.0"
  },
  "devDependencies": {
    "@signalk/server-api": "^2.24.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@types/suncalc": "^1.9.2",
    "baconjs": "^3.0.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-json-equal": "0.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalK/signalk-derived-data"
  }
}
