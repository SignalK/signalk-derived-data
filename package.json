{
  "name": "signalk-derived-data",
  "version": "1.43.2",
  "description": "Plugin that derives signalk data from other signalk data",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "precommit": "lint-staged",
    "prettier:check": "prettier --check .",
    "prettier": "prettier --write .",
    "format": "npm run prettier",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "mutation": "stryker run",
    "prepublishOnly": "npm run build"
  },
  "c8": {
    "extension": [
      ".ts"
    ],
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "test/**",
      "coverage/**",
      "dist/**",
      "src/types.ts",
      "src/types/**",
      "src/calcs/__*.ts"
    ],
    "all": true,
    "reporter": [
      "text",
      "lcov"
    ]
  },
  "keywords": [
    "signalk-node-server-plugin"
  ],
  "author": {
    "name": "Scott Bender",
    "email": "scott@scottbender.net"
  },
  "contributors": [
    {
      "name": "Joachim Bakke"
    }
  ],
  "license": "Apache-2.0",
  "lint-staged": {
    "*.ts": "prettier --write"
  },
  "dependencies": {
    "cubic-spline": "^3.0.3",
    "geolib": "^3.3.1",
    "geolocation-utils": "^1.2.3",
    "geomagnetism": "^0.2.0",
    "suncalc": "^1.8.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/mocha-runner": "^9.6.1",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/suncalc": "^1.9.2",
    "baconjs": "^3.0.0",
    "c8": "^11.0.0",
    "chai": "^4.5.0",
    "chai-json-equal": "0.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SignalK/signalk-derived-data"
  }
}
